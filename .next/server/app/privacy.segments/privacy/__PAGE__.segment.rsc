0:{"buildId":"dZS0rZiyM0Kme65bQCkuI","rsc":["$","$1","c",{"children":[["$","main",null,{"style":{"padding":"2rem","maxWidth":900,"margin":"0 auto"},"children":[["$","$L2",null,{}],["$","h1",null,{"children":"Privacy Policy — LEARN (Lanchester Early Access Research Network)"}],["$","p",null,{"children":[["$","strong",null,{"children":"Effective date:"}]," March 18, 2026"]}],["$","h2",null,{"children":"Introduction"}],["$","p",null,{"children":"Welcome to LEARN (Lanchester Early Access Research Network). This Privacy Policy explains how Lanchester R&D (“we”, “us”, “our”) collects, uses, discloses, and protects personal data when you use LEARN — a platform that helps people discover digital products, join waitlists, follow projects, and receive updates. We are committed to protecting your privacy and complying with applicable data protection laws, including the EU General Data Protection Regulation (“GDPR\") and applicable UK/EU regulations."}],["$","h2",null,{"children":"Data Controller"}],["$","ul",null,{"children":[["$","li",null,{"children":"Data Controller: Lanchester R&D"}],["$","li",null,{"children":"Registered address: 40 Windmill Drive, Audlem, UK"}],["$","li",null,{"children":"Contact email (privacy): lanchester.rd@gmail.com"}],["$","li",null,{"children":"Data Protection / Privacy contact: Thomas Richardson (lanchester.rd@gmail.com)"}]]}],["$","h2",null,{"children":"What Data We Collect"}],["$","p",null,{"children":"We collect the following categories of personal data when you use LEARN:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Identity and account data:"}]," full name (if provided), email address, authentication provider identifier (Google OAuth user ID or internal account ID used for magic-link sign-in)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Profile and preference data:"}]," user preferences and settings, display name and optional profile fields."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Product and waitlist data:"}]," products you follow or waitlists you join, timestamps and membership metadata."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communications and engagement:"}]," email history, email engagement metadata (opens/clicks), replies or messages you send."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Technical and usage data:"}]," device and browser information, IP addresses, logs, page views, and usage events."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Support and feedback:"}]," messages you send to support or admins and attachments."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Administrative logs (admins only):"}]," admin actions and identifiers."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Aggregated data:"}]," anonymized analytics derived from the above."]}]]}],["$","h2",null,{"children":"How We Collect Data"}],["$","p",null,{"children":"We collect data directly from you (registration, interactions), automatically (cookies, logs), and from third parties (Google on OAuth, service providers such as Resend and Firebase)."}],["$","h2",null,{"children":"Legal Basis for Processing (GDPR)"}],["$","p",null,{"children":"For users in the EU/EEA/UK we rely on a combination of:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Performance of a contract:"}]," to provide the Service and operate accounts."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Consent:"}]," for marketing, non-essential cookies, and optional tracking."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legitimate interests:"}]," to operate, secure, and improve the Service (balanced against user rights)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal obligation:"}]," where retention or disclosure is required by law."]}]]}],["$","h2",null,{"children":"How We Use Data"}],["$","p",null,{"children":"We use personal data to provide and operate the Service, send transactional and product emails, support Google sign-in, enable admins to manage products and campaigns, improve the Service via analytics (with consent where required), detect and prevent fraud, and comply with legal obligations."}],"$L3","$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17"]}],null,"$L18"]}],"loading":null,"isPartial":false}
3:["$","h2",null,{"children":"Email Communications"}]
4:["$","p",null,{"children":"Transactional emails (magic links, confirmations, security alerts) are necessary for account operation. Product updates and campaign emails are sent with consent where required; you may opt out at any time. We may use tracking pixels and link tagging to measure opens and clicks; tracked marketing emails require consent where applicable."}]
5:["$","h2",null,{"children":"Third-Party Services and Processors"}]
6:["$","p",null,{"children":"We use processors who act on our behalf, including:"}]
7:["$","ul",null,{"children":[["$","li",null,{"children":["Firebase (Google) — Authentication, Firestore, Cloud Functions, Hosting. See: ",["$","a",null,{"href":"https://firebase.google.com/support/privacy","target":"_blank","rel":"noopener noreferrer","children":"Firebase privacy"}]," and ",["$","a",null,{"href":"https://policies.google.com/privacy","target":"_blank","rel":"noopener noreferrer","children":"Google privacy"}],"."]}],["$","li",null,{"children":["Google OAuth — sign-in and identity tokens. See: ",["$","a",null,{"href":"https://developers.google.com/identity","target":"_blank","rel":"noopener noreferrer","children":"Google Identity"}],"."]}],["$","li",null,{"children":["Resend — transactional and campaign email delivery and engagement reporting. See: ",["$","a",null,{"href":"https://resend.com/privacy","target":"_blank","rel":"noopener noreferrer","children":"Resend privacy"}],"."]}]]}]
8:["$","h2",null,{"children":"Data Sharing"}]
9:["$","p",null,{"children":"We do not sell your personal data. We may share data with processors, to comply with legal requests, to protect rights and safety, as part of a business transfer, or as aggregated anonymized data."}]
a:["$","h2",null,{"children":"Data Retention"}]
b:["$","p",null,{"children":"We retain data only as long as necessary. Examples: account data until deletion (+90 days for backups), product-follow records up to 3 years after last activity, email logs up to 3 years, support messages up to 3 years. Aggregated analytics may be retained in anonymized form indefinitely."}]
c:["$","h2",null,{"children":"Your Rights (EU/EEA/UK)"}]
d:["$","p",null,{"children":"You may exercise rights including access, rectification, erasure, restriction, portability, objection, and withdrawal of consent. To exercise rights contact: lanchester.rd@gmail.com. You may also lodge a complaint with your local supervisory authority."}]
e:["$","h2",null,{"children":"Data Security"}]
f:["$","p",null,{"children":"We implement reasonable organizational and technical measures: TLS, provider-supported encryption at rest, role-based access control, logging, monitoring, and incident response. We will notify affected users and regulators when required by law."}]
10:["$","h2",null,{"children":"International Transfers"}]
11:["$","p",null,{"children":"Data may be transferred outside the EU/EEA/UK (e.g., to the US). We rely on appropriate safeguards such as Standard Contractual Clauses, adequacy decisions, and contractual protections. Contact us for copies of safeguards."}]
12:["$","h2",null,{"children":"Children’s Data"}]
13:["$","p",null,{"children":"LEARN is not directed to children under 16. We do not knowingly collect data from children under 16. If you believe a child under 16 has provided data, contact lanchester.rd@gmail.com for deletion."}]
14:["$","h2",null,{"children":"Changes to This Policy"}]
15:["$","p",null,{"children":"We may update this Privacy Policy. Material changes will be posted here with a revised effective date and, where appropriate, notified to you."}]
16:["$","h2",null,{"children":"Contact"}]
17:["$","p",null,{"children":["For privacy questions or requests:",["$","br",null,{}],"Email: lanchester.rd@gmail.com",["$","br",null,{}],"Postal: 40 Windmill Drive, Audlem, UK",["$","br",null,{}],"Data contact / DPO: Thomas Richardson (lanchester.rd@gmail.com)"]}]
