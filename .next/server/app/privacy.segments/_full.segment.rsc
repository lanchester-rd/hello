c:["$","$1","c",{"children":[["$","main",null,{"style":{"padding":"2rem","maxWidth":900,"margin":"0 auto"},"children":[["$","$L8",null,{}],["$","h1",null,{"children":"Privacy Policy — LEARN (Lanchester Early Access Research Network)"}],["$","p",null,{"children":[["$","strong",null,{"children":"Effective date:"}]," March 18, 2026"]}],["$","h2",null,{"children":"Introduction"}],["$","p",null,{"children":"Welcome to LEARN (Lanchester Early Access Research Network). This Privacy Policy explains how Lanchester R&D (“we”, “us”, “our”) collects, uses, discloses, and protects personal data when you use LEARN — a platform that helps people discover digital products, join waitlists, follow projects, and receive updates. We are committed to protecting your privacy and complying with applicable data protection laws, including the EU General Data Protection Regulation (“GDPR\") and applicable UK/EU regulations."}],["$","h2",null,{"children":"Data Controller"}],["$","ul",null,{"children":[["$","li",null,{"children":"Data Controller: Lanchester R&D"}],["$","li",null,{"children":"Registered address: 40 Windmill Drive, Audlem, UK"}],["$","li",null,{"children":"Contact email (privacy): lanchester.rd@gmail.com"}],["$","li",null,{"children":"Data Protection / Privacy contact: Thomas Richardson (lanchester.rd@gmail.com)"}]]}],["$","h2",null,{"children":"What Data We Collect"}],["$","p",null,{"children":"We collect the following categories of personal data when you use LEARN:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Identity and account data:"}]," full name (if provided), email address, authentication provider identifier (Google OAuth user ID or internal account ID used for magic-link sign-in)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Profile and preference data:"}]," user preferences and settings, display name and optional profile fields."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Product and waitlist data:"}]," products you follow or waitlists you join, timestamps and membership metadata."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communications and engagement:"}]," email history, email engagement metadata (opens/clicks), replies or messages you send."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Technical and usage data:"}]," device and browser information, IP addresses, logs, page views, and usage events."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Support and feedback:"}]," messages you send to support or admins and attachments."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Administrative logs (admins only):"}]," admin actions and identifiers."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Aggregated data:"}]," anonymized analytics derived from the above."]}]]}],["$","h2",null,{"children":"How We Collect Data"}],["$","p",null,{"children":"We collect data directly from you (registration, interactions), automatically (cookies, logs), and from third parties (Google on OAuth, service providers such as Resend and Firebase)."}],["$","h2",null,{"children":"Legal Basis for Processing (GDPR)"}],["$","p",null,{"children":"For users in the EU/EEA/UK we rely on a combination of:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Performance of a contract:"}]," to provide the Service and operate accounts."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Consent:"}]," for marketing, non-essential cookies, and optional tracking."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legitimate interests:"}]," to operate, secure, and improve the Service (balanced against user rights)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal obligation:"}]," where retention or disclosure is required by law."]}]]}],["$","h2",null,{"children":"How We Use Data"}],["$","p",null,{"children":"We use personal data to provide and operate the Service, send transactional and product emails, support Google sign-in, enable admins to manage products and campaigns, improve the Service via analytics (with consent where required), detect and prevent fraud, and comply with legal obligations."}],"$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24"]}],null,"$L25"]}]
