10:["$","h2",null,{"children":"Email Communications"}]
11:["$","p",null,{"children":"Transactional emails (magic links, confirmations, security alerts) are necessary for account operation. Product updates and campaign emails are sent with consent where required; you may opt out at any time. We may use tracking pixels and link tagging to measure opens and clicks; tracked marketing emails require consent where applicable."}]
12:["$","h2",null,{"children":"Third-Party Services and Processors"}]
13:["$","p",null,{"children":"We use processors who act on our behalf, including:"}]
14:["$","ul",null,{"children":[["$","li",null,{"children":["Firebase (Google) — Authentication, Firestore, Cloud Functions, Hosting. See: ",["$","a",null,{"href":"https://firebase.google.com/support/privacy","target":"_blank","rel":"noopener noreferrer","children":"Firebase privacy"}]," and ",["$","a",null,{"href":"https://policies.google.com/privacy","target":"_blank","rel":"noopener noreferrer","children":"Google privacy"}],"."]}],["$","li",null,{"children":["Google OAuth — sign-in and identity tokens. See: ",["$","a",null,{"href":"https://developers.google.com/identity","target":"_blank","rel":"noopener noreferrer","children":"Google Identity"}],"."]}],["$","li",null,{"children":["Resend — transactional and campaign email delivery and engagement reporting. See: ",["$","a",null,{"href":"https://resend.com/privacy","target":"_blank","rel":"noopener noreferrer","children":"Resend privacy"}],"."]}]]}]
15:["$","h2",null,{"children":"Data Sharing"}]
16:["$","p",null,{"children":"We do not sell your personal data. We may share data with processors, to comply with legal requests, to protect rights and safety, as part of a business transfer, or as aggregated anonymized data."}]
17:["$","h2",null,{"children":"Data Retention"}]
18:["$","p",null,{"children":"We retain data only as long as necessary. Examples: account data until deletion (+90 days for backups), product-follow records up to 3 years after last activity, email logs up to 3 years, support messages up to 3 years. Aggregated analytics may be retained in anonymized form indefinitely."}]
19:["$","h2",null,{"children":"Your Rights (EU/EEA/UK)"}]
1a:["$","p",null,{"children":"You may exercise rights including access, rectification, erasure, restriction, portability, objection, and withdrawal of consent. To exercise rights contact: lanchester.rd@gmail.com. You may also lodge a complaint with your local supervisory authority."}]
1b:["$","h2",null,{"children":"Data Security"}]
1c:["$","p",null,{"children":"We implement reasonable organizational and technical measures: TLS, provider-supported encryption at rest, role-based access control, logging, monitoring, and incident response. We will notify affected users and regulators when required by law."}]
1d:["$","h2",null,{"children":"International Transfers"}]
1e:["$","p",null,{"children":"Data may be transferred outside the EU/EEA/UK (e.g., to the US). We rely on appropriate safeguards such as Standard Contractual Clauses, adequacy decisions, and contractual protections. Contact us for copies of safeguards."}]
1f:["$","h2",null,{"children":"Children’s Data"}]
20:["$","p",null,{"children":"LEARN is not directed to children under 16. We do not knowingly collect data from children under 16. If you believe a child under 16 has provided data, contact lanchester.rd@gmail.com for deletion."}]
21:["$","h2",null,{"children":"Changes to This Policy"}]
22:["$","p",null,{"children":"We may update this Privacy Policy. Material changes will be posted here with a revised effective date and, where appropriate, notified to you."}]
23:["$","h2",null,{"children":"Contact"}]
24:["$","p",null,{"children":["For privacy questions or requests:",["$","br",null,{}],"Email: lanchester.rd@gmail.com",["$","br",null,{}],"Postal: 40 Windmill Drive, Audlem, UK",["$","br",null,{}],"Data contact / DPO: Thomas Richardson (lanchester.rd@gmail.com)"]}]
