c:["$","$1","c",{"children":[["$","main",null,{"style":{"padding":"2rem","maxWidth":900,"margin":"0 auto"},"children":[["$","$L8",null,{}],["$","h1",null,{"children":"Terms and Conditions — LEARN (Lanchester Early Access Research Network)"}],["$","p",null,{"children":[["$","strong",null,{"children":"Effective date:"}]," March 18, 2026"]}],["$","h2",null,{"children":"1. Introduction and Acceptance"}],["$","p",null,{"children":"These Terms and Conditions (“Terms”) govern your use of LEARN provided by Lanchester R&D (“we”, “us”, “our”). By accessing or using the Service you agree to these Terms and our Privacy Policy. If you do not agree, do not use the Service."}],["$","h2",null,{"children":"2. Definitions"}],["$","p",null,{"children":"“Service” means the LEARN platform and related websites, applications, APIs, and services."}],["$","h2",null,{"children":"3. Eligibility"}],["$","p",null,{"children":"You must be at least 16 years old (or the minimum age in your jurisdiction where lower and lawful) to use the Service. By using the Service you represent and warrant that you meet these requirements."}],["$","h2",null,{"children":"4. Account Registration and Authentication"}],["$","p",null,{"children":[["$","strong",null,{"children":"Google Sign-In (OAuth):"}]," You may sign in using Google OAuth. You authorize the retrieval of permitted profile information (name, email, id). We do not receive your Google password."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Magic Link Email Authentication:"}]," You may sign in using a magic link sent to your email address. Magic links are time-limited and single-use."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Consent at Registration:"}]," To create an account, you must accept essential terms and provide required consents for non-essential cookies and marketing only where we request them. Non-essential cookies and tracking will be disabled until you grant consent."]}],["$","h2",null,{"children":"5. Use of the Platform"}],["$","p",null,{"children":"Use the Service lawfully. Admins may create, edit, or delete product entries, send campaign emails, and view engagement and analytics data. Admin actions are logged."}],["$","h2",null,{"children":"6. Product Disclaimer"}],["$","p",null,{"children":"Products listed on LEARN are experimental and may change or be discontinued. Listing does not constitute endorsement and participation is at your own risk."}],["$","h2",null,{"children":"7. Email and Communications"}],["$","p",null,{"children":"Transactional emails are required for account operation. Marketing and product updates are sent with consent; you may opt out at any time. Email tracking may be used with consent."}],["$","h2",null,{"children":"8. Intellectual Property"}],["$","p",null,{"children":"All rights in the Service and content are owned by Lanchester R&D or licensed to us. You retain ownership of User Content but grant us a non-exclusive license to host and use it to operate the Service."}],["$","h2",null,{"children":"9. User Content and Moderation"}],["$","p",null,{"children":"You are responsible for User Content. We may remove or restrict content that violates these Terms."}],["$","h2",null,{"children":"10. Availability and Changes"}],["$","p",null,{"children":"We aim for reliable service but make no guarantee of uninterrupted availability. We may modify or discontinue features at any time."}],["$","h2",null,{"children":"11. Limitation of Liability"}],["$","p",null,{"children":"To the fullest extent permitted by law, Lanchester R&D will not be liable for indirect, incidental, special, punitive, or consequential damages. Our aggregate liability is limited to the greater of fees paid in the prior 12 months or €100, subject to consumer protections."}],"$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b"]}],null,"$L1c"]}]
